{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adversaries.schema.json",
  "title": "Adversarios (Stonepaths y otros): bloque completo de estadísticas.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["name", "role", "rol", "rango", "tipo", "attrs", "vitals", "lines", "rasgos", "acciones"],
    "properties": {
      "name":  { "type": "string", "minLength": 1 },
      "role":  { "type": "string", "minLength": 1 },
      "rol":   { "type": "string", "enum": ["Secuaz", "Rival", "Jefe"] },
      "rango": { "type": "string" },
      "tipo":  { "type": "string", "minLength": 1 },
      "attrs": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fis", "cog", "esp"],
        "properties": {
          "fis": { "$ref": "#/$defs/pairList" },
          "cog": { "$ref": "#/$defs/pairList" },
          "esp": { "$ref": "#/$defs/pairList" }
        }
      },
      "vitals":  { "$ref": "#/$defs/pairList" },
      "lines":   { "$ref": "#/$defs/pairList" },
      "rasgos":  { "$ref": "#/$defs/pairList" },
      "acciones": {
        "type": "array",
        "items": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "prefixItems": [
            { "type": "string" },
            { "type": "string" },
            { "type": ["string", "null"] },
            { "type": "string" }
          ],
          "items": false
        }
      },
      "tactics": { "type": ["string", "null"] },
      "oyc":     {
        "type": ["array", "null"],
        "items": { "$ref": "#/$defs/pairList/items" }
      }
    }
  },
  "$defs": {
    "pairList": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": { "type": "string" }
      }
    }
  }
}
